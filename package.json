{
  "name": "thom4.net",
  "version": "4.0.1",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">= 22.0.0"
  },
  "scripts": {
    "build": "eleventy",
    "postbuild": "node --run build:index",
    "build:index": "pagefind --site _site",
    "predeploy": "NODE_ENV=production node --run build",
    "deploy": "eleventy deploy",
    "start": "eleventy --serve",
    "new:journal": "./bin/new-journal-entry",
    "pretest": "NODE_ENV=production npm run build",
    "test": "exit 0"
  },
  "dependencies": {
    "@11ty/eleventy": "^3.1.5",
    "@11ty/eleventy-img": "^6.0.4",
    "@11ty/eleventy-navigation": "^1.0.5",
    "@11ty/eleventy-plugin-rss": "^3.0.0",
    "@11ty/eleventy-plugin-syntaxhighlight": "^5.0.2",
    "@11ty/eleventy-plugin-webc": "^0.11.2",
    "@iarna/toml": "^2.2.5",
    "@turf/bbox": "^7.3.4",
    "entities": "^8.0.0",
    "maplibre-gl": "^5.23.0",
    "markdown-it-abbr": "^2.0.0",
    "markdown-it-anchor": "^9.2.0",
    "markdown-it-attrs": "^4.3.1",
    "markdown-it-bracketed-spans": "^1.0.1",
    "markdown-it-container": "^4.0.0",
    "markdown-it-emoji": "^3.0.0",
    "markdown-it-footnote": "^4.0.0",
    "markdown-it-for-inline": "^2.0.1",
    "markdown-it-mark": "^4.0.0",
    "mime": "^4.1.0",
    "normalize.css": "^8.0.1",
    "pagefind": "^1.5.0",
    "reading-time": "^1.5.0",
    "reveal-random-colors": "^2.1.0",
    "reveal.js": "^6.0.0"
  },
  "devDependencies": {
    "promptly": "^3.2.0"
  }
}
