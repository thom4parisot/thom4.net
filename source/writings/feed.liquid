---
permalink: /feed/atom.xml
eleventyExcludeFromCollections: true
layout: ~
feed:
  title: "Thomas Parisot — Carnet Web"
  description: "Écrits sous forme d'articles long et notes de journal."
  language: "fr"
  base: "https://thom4.net"
  author:
    name: "Thomas Parisot"
---
{%- assign posts = collections.posts | concat: collections.journal | sort: 'data.date' | reverse -%}
<?xml version="1.0" encoding="utf-8"?>
<feed xmlns="http://www.w3.org/2005/Atom" xml:lang="{{ metadata.language | default: page.lang }}">
  <title>{{ feed.title }}</title>
  <subtitle>{{ feed.description }}</subtitle>
  <icon>{{ '/assets/favicon.svg' | htmlBaseUrl: feed.base }}</icon>
  <link href="{{ permalink | htmlBaseUrl: feed.base }}" rel="self" />
  <link href="{{ feed.base | addPathPrefixToFullUrl }}" />
  <updated>{{ posts | getNewestCollectionItemDate | dateToRfc3339 }}</updated>
  <id>{{ feed.base | addPathPrefixToFullUrl }}</id>
  <author>
    <name>{{ feed.author.name }}</name>
  </author>
  {% for post in posts, limit: 10 %}
  {%- assign absolutePostUrl = post.url | htmlBaseUrl: feed.base %}
  <entry xml:lang="{{ post.data.lang }}">
    <id>{{ absolutePostUrl }}</id>
    <title>{{ post.data.title | escape }}</title>
    <link href="{{ absolutePostUrl }}" hreflang="{{ post.data.lang }}" />
    <updated>{{ post.date | dateToRfc3339 }}</updated>
    {%- if post.page.excerpt != nil  %}
    <summary type="html"><![CDATA[{{ post.page.excerpt | default: '' | renderTransforms: post.data.page, feed.base }}]]></summary>
    {%- endif %}
    {%- if post.content %}
    <content type="html"><![CDATA[{{ post.content | renderTransforms: post.data.page, feed.base }}]]></content>
    {%- endif %}
    {%- for category in post.data.categories %}
    <category term="{{ category | escape }}"/>
    {%- endfor %}
    {%- for category in post.data.tags %}
    <category term="{{ category | escape }}"/>
    {% endfor -%}
    {%- for picture in post.data.pictures %}
    {%- if picture.src == nil -%}{% continue %}{% endif %}
    <link rel="enclosure" type="{{ picture.src | mimeType }}" href="{{ picture.src | htmlBaseUrl: absolutePostUrl }}" {% if picture.comment %}title="{{ picture.comment | default: '' | renderContent: 'md' | strip_html | strip_newlines }}"{% endif %} />
    {%- endfor %}
  </entry>
  {%- endfor %}
</feed>